{
    "name": "mori-elastic-search/mori-elastic-search",
    "description": "Convert PDF to searchable text with Elasticsearch integration for fast full-text search in Shopware 6.",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "shopware/core": "~6.7.0",
        "opensearch-project/opensearch-php": "^2.0"
    },
    "extra": {
        "shopware-plugin-class": "MoriElasticSearch\\MoriElasticSearch",
        "plugin-icon": "src/Resources/config/images/plugin.png",
        "label": {
            "de-DE": "Mori elasticserach pdf plugin",
            "en-GB": "Mori elasticserach pdf plugin"
        },
        "copyright": "(c) by Mori GmbH",
        "description": {
            "de-DE": "Convert PDF to searchable text with Elasticsearch integration for fast full-text search in Shopware 6.",
            "en-GB": "PDF in durchsuchbaren Text konvertieren mit Elasticsearch-Integration für eine schnelle Volltextsuche in Shopware 6."
        },
        "manufacturerLink": {
            "de-DE": "pedramham1@gmail.com",
            "en-GB": "pedramham1@gmail.com"
        }
    },
    "autoload": {
        "psr-4": {
            "MoriElasticSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MoriElasticSearch\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "symplify/easy-coding-standard": "^11.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
